# intellij idea project files
/.idea/

# fake build artifacts
/.fake/

# binary output directories
/bin/

# object files
/obj/

# test result directories
/TestResults/

# user-specific settings
Folder.DotSettings.user

# csv files of all deleted submissions
/data/Removed/

# csv files of all executed tests
/data/Tests/

# exclude all nested directories under exercises
/data/Exercises/*/*

# include only statistics
!/data/Exercises/**/Statistics/
